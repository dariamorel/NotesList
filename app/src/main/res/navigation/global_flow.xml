<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/global_flow"
    app:startDestination="@id/notesListFragment">

    <fragment
        android:id="@+id/notesListFragment"
        android:name="com.example.noteslist.presentation.ui.notes_list_screen.NotesListFragment"
        tools:layout="@layout/fragment_notes_list" >

        <action
            android:id="@+id/navigateToAddNoteFragment"
            app:destination="@id/addNoteFragment" />

        <action
            android:id="@+id/navigateToEditNoteFragment"
            app:destination="@id/editNoteFragment">

            <argument
                android:name="note"
                app:argType="com.example.noteslist.domain.Note"
                app:nullable="false" />
        </action>
    </fragment>

    <fragment
        android:id="@+id/addNoteFragment"
        android:name="com.example.noteslist.presentation.ui.add_note_screen.AddNoteFragment">

        <action
            android:id="@+id/navigateToRecyclerViewFragment"
            app:destination="@id/notesListFragment" />

    </fragment>

    <fragment
        android:id="@+id/editNoteFragment"
        android:name="com.example.noteslist.presentation.ui.edit_note_screen.EditNoteFragment">

        <argument
            android:name="note"
            app:argType="com.example.noteslist.domain.Note"
            app:nullable="false" />

        <action
            android:id="@+id/navigateToRecyclerViewFragment"
            app:destination="@id/notesListFragment" />

    </fragment>


</navigation>